{
  "name": "builder",
  "version": "1.0.0",
  "description": "CLI tool for building @oneo/fluentui-icons-like",
  "type": "module",
  "bin": {
    "builder": "./dist/index.js"
  },
  "scripts": {
    "check": "biome check --write",
    "sync": "tsc && node dist/index.js sync",
    "generate": "tsc && node dist/index.js generate",
    "pack": "tsc && node dist/index.js pack"
  },
  "packageManager": "pnpm@10.23.0",
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/node": "^22.19.17",
    "typescript": "^5.9.3"
  }
}
