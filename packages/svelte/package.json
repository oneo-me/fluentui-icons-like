{
  "name": "@oneo/fluentui-icons-like",
  "version": "2.0.0-preview.0",
  "description": "Microsoft Fluent UI System Icons as Svelte 5 runes-mode components. Tree-shakable, type-safe SVG icons with zero dependencies — import only what you need.",
  "author": "ONEO",
  "license": "MIT",
  "homepage": "https://github.com/oneo-me/fluentui-icons-like#readme",
  "bugs": "https://github.com/oneo-me/fluentui-icons-like/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oneo-me/fluentui-icons-like.git",
    "directory": "packages/svelte"
  },
  "keywords": [
    "svelte",
    "svelte5",
    "sveltekit",
    "fluentui",
    "fluent-ui",
    "fluent",
    "icons",
    "icon",
    "svg",
    "svg-icons",
    "microsoft",
    "system-icons",
    "tree-shakable",
    "runes-mode"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && node scripts/fix-sveltekit-server-side-effects.mjs",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "prepack": "svelte-kit sync && svelte-package -i src/lib/icons && publint",
    "svelte-check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check": "biome check --write",
    "pack": "pnpm pack",
    "publish": "pnpm publish",
    "deploy": "pnpm build && wrangler deploy"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@sveltejs/adapter-cloudflare": "^7.2.8",
    "@sveltejs/kit": "^2.59.1",
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^7.1.1",
    "@tailwindcss/vite": "^4.2.4",
    "publint": "^0.3.19",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.8",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "wrangler": "^4.88.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    "./*.svelte": {
      "types": "./*.svelte.d.ts",
      "svelte": "./*.svelte"
    }
  },
  "files": [
    "../../README.md",
    "logo.png",
    "dist/**"
  ],
  "sideEffects": false
}
