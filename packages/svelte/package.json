{
  "name": "@oneo/fluentui-icons-like",
  "version": "2.0.1",
  "description": "Microsoft Fluent UI System Icons as Svelte 5 runes-mode components. Tree-shakable, type-safe SVG icons with zero dependencies — import only what you need.",
  "author": "ONEO",
  "license": "MIT",
  "homepage": "https://github.com/oneo-me/fluentui-icons-like#readme",
  "bugs": "https://github.com/oneo-me/fluentui-icons-like/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oneo-me/fluentui-icons-like.git",
    "directory": "packages/svelte"
  },
  "keywords": [
    "svelte",
    "svelte5",
    "sveltekit",
    "fluentui",
    "fluent-ui",
    "fluent",
    "icons",
    "icon",
    "svg",
    "svg-icons",
    "microsoft",
    "system-icons",
    "tree-shakable",
    "runes-mode"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && node scripts/fix-sveltekit-server-side-effects.mjs",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "prepack": "svelte-kit sync && svelte-package -i src/lib/icons && publint",
    "svelte-check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check": "biome check --write",
    "pack": "pnpm pack",
    "publish": "pnpm publish",
    "deploy": "pnpm build && wrangler deploy"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@sveltejs/adapter-cloudflare": "^7.2.8",
    "@sveltejs/kit": "^2.59.1",
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.6.2",
    "publint": "^0.3.20",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.8",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.11",
    "wrangler": "^4.90.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    "./*.svelte": {
      "types": "./dist/*.svelte.d.ts",
      "svelte": "./dist/*.svelte",
      "default": "./dist/*.svelte"
    }
  },
  "files": [
    "screenshot.png",
    "README.md",
    "logo.png",
    "dist/**"
  ],
  "sideEffects": false,
  "packageManager": "pnpm@11.0.9+sha512.34ce82e6780233cf9cad8685029a8f81d2e06196c5a9bad98879f7424940c6817c4e4524fb7d38b8553ceed48b9758b8ebaf1abd3600c232c4c8cf7366086f38"
}
