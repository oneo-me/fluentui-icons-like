{
  "name": "@fluentui-icons-like/svelte",
  "version": "0.0.1",
  "description": "Fluent UI System Icons for Svelte 5",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "predev": "cd ../../builder && pnpm build && pnpm generate",
    "dev": "vite",
    "prebuild": "cd ../../builder && pnpm build && pnpm generate",
    "build": "svelte-package -i src/lib",
    "build:demo": "vite build",
    "preview": "vite preview --outDir dist-demo",
    "generate": "cd ../../builder && pnpm build && pnpm generate"
  },
  "packageManager": "pnpm@10.23.0",
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@sveltejs/package": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tsconfig/svelte": "^5.0.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "exports": {
    "./components/*.svelte": {
      "types": "./dist/components/*.svelte.d.ts",
      "svelte": "./dist/components/*.svelte"
    },
    "./icons/*.svelte": {
      "types": "./dist/icons/*.svelte.d.ts",
      "svelte": "./dist/icons/*.svelte"
    }
  },
  "files": [
    "dist/components",
    "dist/icons"
  ]
}
