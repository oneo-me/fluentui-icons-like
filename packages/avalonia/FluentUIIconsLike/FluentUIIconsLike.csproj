<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
        <PackageId>ONEO.FluentUIIconsLike</PackageId>
        <Version>2.0.0-beta.0</Version>
        <Authors>ONEO</Authors>
        <Description>Microsoft Fluent UI System Icons as Avalonia controls. Lightweight icon rendering for Avalonia applications.</Description>
        <PackageLicenseExpression>MIT</PackageLicenseExpression>
        <PackageProjectUrl>https://github.com/oneo-me/fluentui-icons-like#readme</PackageProjectUrl>
        <RepositoryUrl>https://github.com/oneo-me/fluentui-icons-like.git</RepositoryUrl>
        <RepositoryType>git</RepositoryType>
        <PackageTags>avalonia;fluentui;fluent-ui;fluent;icons;icon;svg;microsoft;system-icons</PackageTags>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <PublishRepositoryUrl>true</PublishRepositoryUrl>
    </PropertyGroup>
    <ItemGroup>
        <PackageReference Include="Avalonia" />
    </ItemGroup>
    <ItemGroup>
        <None Include="../../../README.md" Pack="true" PackagePath="README.md" />
    </ItemGroup>
</Project>
