<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <IsAotCompatible>false</IsAotCompatible>
        <TargetFramework>netstandard2.0</TargetFramework>
        <EnforceExtendedAnalyzerRules>true</EnforceExtendedAnalyzerRules>
        <DevelopmentDependency>true</DevelopmentDependency>
        <BuildOutputTargetFolder>analyzers/dotnet/cs</BuildOutputTargetFolder>
        <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
        <NoWarn>NU5128;RS2008</NoWarn>
        <PackageId>ONEO.FluentUIIconsLike.Generator</PackageId>
        <Description>Source generator for ONEO FluentUI Icons Like on Avalonia. Generates icon data for referenced symbols.</Description>
        <PackageTags>avalonia;fluentui;fluent-ui;fluent;icons;icon;source-generator;roslyn;microsoft;system-icons</PackageTags>
    </PropertyGroup>
    <ItemGroup>
        <PackageReference Include="Microsoft.CodeAnalysis.CSharp" PrivateAssets="all" />
        <PackageReference Include="Microsoft.CodeAnalysis.Analyzers" PrivateAssets="all" />
        <PackageReference Include="System.Text.Json" PrivateAssets="all" />
    </ItemGroup>
    <ItemGroup>
        <EmbeddedResource Include="Assets\fluent-icons.json" />
    </ItemGroup>
    <ItemGroup>
        <None Include="../../../README.md" Pack="true" PackagePath="README.md" />
        <None Include="../../../logo.png" Pack="true" PackagePath="logo.png" />
    </ItemGroup>
</Project>
