<Window x:Class="FluentUIIconsLikeDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:icons="https://github.com/oneo-me/fluentui-icons-like"
        Title="Fluent UI Icons Like - WPF Demo"
        Width="800" Height="600"
        WindowStartupLocation="CenterScreen">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
        <StackPanel Margin="24" Orientation="Vertical">
            <TextBlock FontSize="20" FontWeight="Bold" Margin="0,0,0,16">Fluent UI Icons Like - WPF Demo</TextBlock>

            <Border BorderBrush="Gray" BorderThickness="1" Padding="16" Margin="0,0,0,16" CornerRadius="8">
                <StackPanel Orientation="Vertical">
                    <TextBlock FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8">Basic Usage</TextBlock>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <icons:FluentIcon Symbol="AccessTime" Size="Size24" Style="Regular" Margin="8" />
                        <icons:FluentIcon Symbol="Accessibility" Size="Size24" Style="Regular" Foreground="Blue" Margin="8" />
                        <icons:FluentIcon Symbol="Add" Size="Size24" Style="Regular" Foreground="Green" Margin="8" />
                        <icons:FluentIcon Symbol="Airplane" Size="Size24" Style="Regular" Foreground="Red" Margin="8" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border BorderBrush="Gray" BorderThickness="1" Padding="16" Margin="0,0,0,16" CornerRadius="8">
                <StackPanel Orientation="Vertical">
                    <TextBlock FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8">Different Sizes</TextBlock>
                    <WrapPanel HorizontalAlignment="Center">
                        <StackPanel Margin="8" VerticalAlignment="Bottom" HorizontalAlignment="Center">
                            <icons:FluentIcon Symbol="Add" Size="Size12" Style="Regular" Margin="4" />
                            <TextBlock FontSize="10" TextAlignment="Center">12</TextBlock>
                        </StackPanel>
                        <StackPanel Margin="8" VerticalAlignment="Bottom" HorizontalAlignment="Center">
                            <icons:FluentIcon Symbol="Add" Size="Size16" Style="Regular" Margin="4" />
                            <TextBlock FontSize="10" TextAlignment="Center">16</TextBlock>
                        </StackPanel>
                        <StackPanel Margin="8" VerticalAlignment="Bottom" HorizontalAlignment="Center">
                            <icons:FluentIcon Symbol="Add" Size="Size20" Style="Regular" Margin="4" />
                            <TextBlock FontSize="10" TextAlignment="Center">20</TextBlock>
                        </StackPanel>
                        <StackPanel Margin="8" VerticalAlignment="Bottom" HorizontalAlignment="Center">
                            <icons:FluentIcon Symbol="Add" Size="Size24" Style="Regular" Margin="4" />
                            <TextBlock FontSize="10" TextAlignment="Center">24</TextBlock>
                        </StackPanel>
                        <StackPanel Margin="8" VerticalAlignment="Bottom" HorizontalAlignment="Center">
                            <icons:FluentIcon Symbol="Add" Size="Size28" Style="Regular" Margin="4" />
                            <TextBlock FontSize="10" TextAlignment="Center">28</TextBlock>
                        </StackPanel>
                        <StackPanel Margin="8" VerticalAlignment="Bottom" HorizontalAlignment="Center">
                            <icons:FluentIcon Symbol="Add" Size="Size32" Style="Regular" Margin="4" />
                            <TextBlock FontSize="10" TextAlignment="Center">32</TextBlock>
                        </StackPanel>
                        <StackPanel Margin="8" VerticalAlignment="Bottom" HorizontalAlignment="Center">
                            <icons:FluentIcon Symbol="Add" Size="Size48" Style="Regular" Margin="4" />
                            <TextBlock FontSize="10" TextAlignment="Center">48</TextBlock>
                        </StackPanel>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border BorderBrush="Gray" BorderThickness="1" Padding="16" Margin="0,0,0,16" CornerRadius="8">
                <StackPanel Orientation="Vertical">
                    <TextBlock FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8">Different Styles</TextBlock>
                    <WrapPanel HorizontalAlignment="Center">
                        <StackPanel Margin="8" HorizontalAlignment="Center">
                            <icons:FluentIcon Symbol="Add" Size="Size24" Style="Regular" Margin="4" />
                            <TextBlock FontSize="10" TextAlignment="Center">Regular</TextBlock>
                        </StackPanel>
                        <StackPanel Margin="8" HorizontalAlignment="Center">
                            <icons:FluentIcon Symbol="Add" Size="Size24" Style="Filled" Margin="4" Foreground="#0078D4" />
                            <TextBlock FontSize="10" TextAlignment="Center">Filled</TextBlock>
                        </StackPanel>
                        <StackPanel Margin="8" HorizontalAlignment="Center">
                            <icons:FluentIcon Symbol="Add" Size="Size24" Style="Light" Margin="4" Foreground="#888888" />
                            <TextBlock FontSize="10" TextAlignment="Center">Light</TextBlock>
                        </StackPanel>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Window>
